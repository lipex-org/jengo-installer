#!/usr/bin/env php
<?php

/**
 * Jengo CLI Installer
 * 
 * (c) 2026 JengoPHP <hello@jengophp.com>
 */

if (file_exists(__DIR__ . '/../vendor/autoload.php')) {
    require __DIR__ . '/../vendor/autoload.php';
} else {
    require __DIR__ . '/autoload.php'; // if installed globally
}

use Symfony\Component\Console\Application;
use Jengo\Installer\Commands\NewCommand;

$app = new Application('Jengo Installer', '1.0.0');

$app->addCommand(new NewCommand());

$app->run();
